                 put mes(t), energiah.l(t),energiat.l(t),energiag.l(t)/;
         );

         put '____________________________________________________________________________________'/;
         put '                                                                                     '/;

         put @9'Evolución de embalses (Mm3)'/;
         put @9'Bloque', @21'Guajoyo', @33'Cgrande', @45'5nov', @57'15sept', @69'Chaparral',@81'Cimarrón'/ ;
         loop(t,
                 put mes(t), vole.l('guaj',t), vole.l('cergde',t), vole.l('5nov',t), vole.l('15set',t), volf.l('chaparral',t), volf.l('cimarron',t)/;
         );
         put '____________________________________________________________________________________'/;


         put 'Producción Hidráulica de centrales existentes y futuras (MW en cada bloque )'/;
         put @9'Bloque', @20'Guajoyo', @31'Cgrande', @44'5nov', @56'15sept', @69'Chaparral',@81'Cimarrón'/ ;
         loop(t$(ord(t) gt 1),
                 put mes(t), phe.l('guaj',t), phe.l('cergde',t), phe.l('5nov',t), phe.l('15set',t), phf.l('chaparral',t), phf.l('cimarron',t)/;
         );

         put '____________________________________________________________________________________'/;
         put '                                                                                     '/;

         put 'Producción Geotérmica de centrales existentes y futuras (MW en cada bloque )'/;
         put @9'Bloque', @20'Ahuachapan', @31'Berlin', @45'Chinameca'/ ;
*
         loop(t$(ord(t) gt 1),
                 put mes(t), pgeo.l('ahua',t), pgeo.l('berlin',t), pgeof.l('chinameca',t)/;
         );

         put '____________________________________________________________________________________'/;

         put @9'Producción de Térmica existentes a bunker(MW en cada bloque)'/;
         put @9'Bloque', @20'AcajutlaTG1', @33'AcajutlaTG2', @45'AcajutlaM' @55'Acajutla TV', @69'Soyapango M', @81'Nejapa M'/;
         loop(t$(ord(t) gt 1),
                 put mes(t), pjeb.l('acajtg1',t), pjeb.l('acajtg2',t), pjeb.l('acajv1',t), pjeb.l('acajm1',t), pjeb.l('soyam',t), pjeb.l('nejapm',t)/;
         );

         put '____________________________________________________________________________________'/;
         put @9'Producción de Térmica existentes a bunker(MW en cada bloque)'/;
         put @9'Bloque', @20'Talnique M' @32'Cessa M', @45'Cassa M', @57'Textufil M', @69'Borealis M', @81'Gecsa M',  @93'Hilcass M'/;
         loop(t$(ord(t) gt 1),
                 put mes(t), pjeb.l('talnim',t), pjeb.l('cessam',t), pjeb.l('cassa',t), pjeb.l('textufilm',t), pjeb.l('borealism',t), pjeb.l('gecsam',t), pjeb.l('hilcasam',t)/;
         );

         put @9'Producción de Térmica futuras a bunker(MW en cada bloque)'/;
         put @9'Bloque', @20'Motores'/;
         loop(t$(ord(t) gt 1),
                 put mes(t), pfb.l('motor',t)/;
         );

         put '____________________________________________________________________________________'/;
         put @9'Producción de Térmica futuras a diesel(MW en cada bloque)'/;
         put @9'Bloque', @21'Turbgas1' @33'Turbgas2', @45'Ccomb1d', @57'Ccomb2d'/;
         loop(t$(ord(t) gt 1),
                 put mes(t), pfd.l('turb1d',t), pfd.l('turb2d',t), pfd.l('diesel1',t), pfd.l('diesel2',t)/;
         );

         put '____________________________________________________________________________________'/;
         put @9'Producción de Térmica futuras a carbón(MW en cada bloque)'/;
         put @9'Bloque', @21'Vapor1', @33'Vapor2'/;
         loop(t$(ord(t) gt 1),
                 put mes(t), pfc.l('Vapcar1',t), pfc.l('Vapcar2',t)/;
         );

         put '____________________________________________________________________________________'/;
         put @9'Producción de Térmica futuras a Gas natural(MW en cada bloque)'/;
         put @9'Bloque', @21'Ccomb1gas', @33'Ccomb2gas'/;
         loop(t$(ord(t) gt 1),
                 put mes(t), pfg.l('gnl1',t), pfg.l('gnl2',t)/;
         );

         put '____________________________________________________________________________________'/;


         put @9'Variables Binarias de ingreso- Centrales Candidatas'/;
         put @9'Bloque',@20'Chaparral',@31'Cimarrón',@45'Chinameca',@57'mbunker', @69'Turbgas1b' @81'Turbgas2b' / ;
         loop(t$(ord(t) gt 1),
                 put mes(t),yh.l('chaparral',t), yh.l('cimarron',t),ygeo.l('chinameca',t),ytb.l('motor',t),ytd.l('turb1d',t), ytd.l('turb2d',t)/;
         );

         put '____________________________________________________________________________________'/;

         put @9'Variables Binarias de ingreso- Centrales Candidatas'/;
         put @9'Bloque',@21'Ccomb1d', @33'Ccomb2d',@45'Vapor1', @57'Vapor2',@69'Ccomb1gnl', @81'Ccomb2gnl'/ ;
         loop(t$(ord(t) gt 1),
                 put mes(t),ytd.l('diesel1',t), ytd.l('diesel2',t),ytc.l('Vapcar1',t),ytc.l('Vapcar2',t),ytg.l('gnl1',t), ytg.l('gnl2',t)/;
         );

         put '____________________________________________________________________________________'/;

         put @9'Variables Binarias de ingreso de Proyectos Precedentes'/;
         put @9'Bloque',@21'Muelle', @33'Regasificación'/ ;
         loop(t$(ord(t) gt 1),
                 put mes(t),yproy.l('muelle',t),yproy.l('regas',t)/;
         );

         put '____________________________________________________________________________________'/;