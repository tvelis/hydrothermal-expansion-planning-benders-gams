COaguae(t,'guaj')$(ord(t) GT 1)         = segH*(inflowguaj.m('guaj',t) - inflowcergde.m('cergde',t))/(0.0001690124*vole.l('guaj',t)+0.243723);
COaguae(t,'cergde')$(ord(t) GT 1)       = segH*(inflowcergde.m('cergde',t) - inflow5nov.m('5nov',t))/ (0.000164485*vole.l('cergde',t)+ 0.239817);
COaguae(t,'5nov')$(ord(t) GT 1)         = segH*(inflow5nov.m('5nov',t) - inflow15set.m('15set',t))/hidroe('5nov','Rho');
COaguae(t,'15set')$(ord(t) GT 1)        = segH*(inflow15set.m('15set',t))/hidroe('15set','Rho');
COaguaf(t,'cimarron')$(ord(t) GT 1)     = segH*(inflowcimarron.m('cimarron',t) - inflowcergde.m('cergde',t))/ (2.249647 + 0.0008527855*volf.l('cimarron',t));
COaguaf(t,'chaparral')$(ord(t) GT 1)    = segH*(inflowchaparral.m('chaparral',t) - inflow15set.m('15set',t))/hidrof('chaparral','Rho');

CMg(t)  = max(COaguae(t,'guaj'), COaguae(t,'cergde'), COaguae(t,'5nov'),COaguae(t,'15set'),COaguaf(t,'cimarron'), COaguaf(t,'chaparral'),balance.m(t));
Ctotal  = inversionmotor + inversionturb1d + inversionturb2d + inversiondiesel1 + inversiondiesel2 + inversionVapcar1 + inversionVapcar2 + inversiongnl1 +inversiongnl2 + inversionchaparral + inversioncimarron + inversionchinameca +inversionmuelle + inversionregas + operacionjeb + operacionjed + operaciongeo + operacionjfb + operacionjfd + operacionjfc + operacionjfg + operaciongeof + operacionurf ;
Cinv    = inversionmotor + inversionturb1d + inversionturb2d + inversiondiesel1 + inversiondiesel2 + inversionVapcar1 + inversionVapcar2 + inversiongnl1 +inversiongnl2 + inversionchaparral + inversioncimarron + inversionchinameca +inversionmuelle + inversionregas ;
cop     = operacionjeb + operacionjed + operaciongeo + operacionjfb + operacionjfd + operacionjfc + operacionjfg + operaciongeof + operacionurf ;
cv(t)   = balance.m(t);

rhoguaj.l(t,'guaj')$(ord(t) GT 1)         = 0.0001690124*vole.l('guaj',t)+0.243723;
rhocerron.l(t,'cergde')$(ord(t) GT 1)     = 0.000164485*vole.l('cergde',t)+ 0.239817;
rhocimarron.l(t,'cimarron')$(ord(t) GT 1) = 2.249647 + 0.0008527855*volf.l('cimarron',t);

energiah.l(t)$(ord(t) GT 1) =  (sum(He,phe.l(He,t)*hrs) + sum(Hf,phf.l(Hf,t)*hrs))/1000;
energiat.l(t)$(ord(t) gt 1) =  (sum(Jeb,pjeb.l(Jeb,t)*hrs)+ sum(Jed,pjed.l(Jed,t)*hrs) + sum(Jfb,pfb.l(Jfb,t)*hrs) + sum(Jfd,pfd.l(Jfd,t)*hrs) + sum(Jfc,pfc.l(Jfc,t)*hrs)+ sum(Jfg,pfg.l(Jfg,t)*hrs))/1000;
energiag.l(t)$(ord(t) gt 1) =  (sum(geo,pgeo.l(geo,t)*hrs)+ sum(geof,pgeof.l(geof,t)*hrs))/1000;

display  Ctotal,inversionmotor, inversionturb1d, inversionturb2d, inversiondiesel1, inversiondiesel2, inversionVapcar1, inversionVapcar2, inversiongnl1, inversiongnl2, inversionchaparral, inversioncimarron, inversionchinameca,inversionmuelle, inversionregas ,operacionjeb,operacionjed,operaciongeo, operacionjfb,operacionjfd,operacionjfc,operacionjfg, operaciongeof,operacionurf,rhoguaj.l,rhocerron.l,rhocimarron.l;
display eh2010,eh2011,eh2012,eh2013,eh2014,eh2015,eh2016,eh2017,eh2018,eh2019,eh2020,eh2021,eh2022,eh2023,eh2024;
